{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:planwright:schema:graph:v1",
  "title": "Planwright Graph v1",
  "description": "Structural schema for Planwright graph JSON. Semantic graph validation is still required after schema validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "provider", "region", "nodes", "edges"],
  "properties": {
    "version": {
      "const": "planwright.graph.v1"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "kind"],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "network.allow",
            "network.route",
            "network.deny",
            "iam.allow",
            "iam.assume_role",
            "iam.pass_role",
            "data.reads_from",
            "data.writes_to",
            "publishes_to",
            "subscribes_to",
            "logs_to",
            "emits_metric_to",
            "depends_on",
            "runs_as",
            "exposes",
            "protects",
            "encrypts_with",
            "backs_up_to",
            "managed_by",
            "generated_from"
          ]
        },
        "protocol": {
          "type": "string",
          "enum": ["tcp", "udp"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "intent": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "network.allow"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["protocol", "port"]
          }
        }
      ]
    },
    "jsonValue": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
